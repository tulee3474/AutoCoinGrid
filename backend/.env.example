PORT=3001
NODE_ENV=production

# 허용할 프론트엔드 출처 (쉼표로 여러 개 설정 가능)
# 예: https://autocoin.yourdomain.com
CORS_ORIGIN=http://localhost

# MySQL 연결 (AWS RDS 또는 로컬)
DATABASE_URL=mysql://autocoin:password@localhost:3306/autocoin

# JWT 서명 키 (랜덤 32자 이상 문자열)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API 키 AES-256 암호화 키 (정확히 32자)
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# 관리자 비밀번호
ADMIN_PASSWORD=danim0504!

# Binance (서버 기본값 — 개인별 키는 각 사용자 DB에 저장)
BINANCE_API_KEY=
BINANCE_API_SECRET=
USE_TESTNET=false
